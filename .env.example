# Embedding Provider Configuration
# Options: "mock" (for development/testing) or "gemini" (for production)
EMBEDDING_PROVIDER=mock

# Embedding dimensions (default: 768)
# Must match the provider's output dimension
EMBEDDING_DIMENSION=768

# Gemini API Configuration (required if EMBEDDING_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-embedding-001

# Clustering Configuration
# Minimum number of records required to form a valid cluster (default: 3)
CLUSTERING_MIN_CLUSTER_SIZE=3

# Minimum cosine similarity (0-1) to form a cluster (default: 0.70)
# Higher = stricter matching, fewer clusters
# Lower = looser matching, more clusters
CLUSTERING_SIMILARITY_THRESHOLD=0.70

# Data directory (optional)
# DATA_DIR=backend/data
